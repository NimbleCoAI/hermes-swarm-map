# Path to directory containing Hermes docker-compose files
HERMES_DIR=~/hermes-agent

# Data directory for Swarm Map config, keys, audit log
DATA_DIR=~/.hermes-swarm-map

# Port for the Swarm Map UI
# Production convention: 3002 (pinned, no auto-increment)
# Dev mode: defaults to 3000, auto-increments if occupied
PORT=3002
